import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import 'package:url_launcher/url_launcher.dart';
import '../constants/categories.dart';
import '../models/reel.dart';
import '../providers/reel_provider.dart';
import 'add_edit_screen.dart';

class BrowseScreen extends StatefulWidget {
  final String? filterCategory;
  const BrowseScreen({super.key, this.filterCategory});

  @override
  State<BrowseScreen> createState() => _BrowseScreenState();
}

class _BrowseScreenState extends State<BrowseScreen> {
  String? _selectedCat;
  bool _showDone = false;
  String _search = '';
  final _searchCtrl = TextEditingController();

  @override
  void initState() {
    super.initState();
    _selectedCat = widget.filterCategory;
  }

  @override
  void dispose() {
    _searchCtrl.dispose();
    super.dispose();
  }

  List<Reel> _filter(List<Reel> all) {
    return all.where((r) {
      if (!_showDone && r.isDone) return false;
      if (_selectedCat != null && r.category != _selectedCat) return false;
      if (_search.isNotEmpty) {
        final q = _search.toLowerCase();
        return r.title.toLowerCase().contains(q) ||
            r.notes.toLowerCase().contains(q) ||
            r.url.toLowerCase().contains(q);
      }
      return true;
    }).toList();
  }

  @override
  Widget build(BuildContext context) {
    final provider = context.watch<ReelProvider>();
    final isSubScreen = widget.filterCategory != null;
    final filtered = _filter(provider.reels);
    final theme = Theme.of(context);

    return Scaffold(
      appBar: AppBar(
        title: Text(
          isSubScreen
              ? categoryById(_selectedCat!).label
              : 'All saved',
        ),
        automaticallyImplyLeading: isSubScreen,
        actions: [
          IconButton(
            icon: Icon(_showDone
                ? Icons.visibility_off_outlined
                : Icons.check_circle_outline),
            tooltip: _showDone ? 'Hide completed' : 'Show completed',
            onPressed: () => setState(() => _showDone = !_showDone),
          ),
        ],
      ),
      body: Column(
        children: [
          Padding(
            padding: const EdgeInsets.fromLTRB(16, 8, 16, 0),
            child: SearchBar(
              controller: _searchCtrl,
              hintText: 'Search reels...',
              leading: const Icon(Icons.search),
              trailing: [
                if (_search.isNotEmpty)
                  IconButton(
                    icon: const Icon(Icons.close),
                    onPressed: () {
                      _searchCtrl.clear();
                      setState(() => _search = '');
                    },
                  ),
              ],
              onChanged: (v) => setState(() => _search = v),
            ),
          ),
          if (!isSubScreen) ...[
            const SizedBox(height: 10),
            SizedBox(
              height: 36,
              child: ListView(
                scrollDirection: Axis.horizontal,
                padding: const EdgeInsets.symmetric(horizontal: 16),
                children: [
                  _Chip(
                    label: 'All',
                    selected: _selectedCat == null,
                    color: theme.colorScheme.primary,
                    onTap: () => setState(() => _selectedCat = null),
                  ),
                  const SizedBox(width: 8),
                  for (final c in kCategories) ...[
                    _Chip(
                      label: c.label.replaceFirst('Want to ', ''),
                      selected: _selectedCat == c.id,
                      color: c.color,
                      onTap: () => setState(() =>
                          _selectedCat = _selectedCat == c.id ? null : c.id),
                    ),
                    const SizedBox(width: 8),
                  ],
                ],
              ),
            ),
          ],
          const SizedBox(height: 8),
          Expanded(
            child: filtered.isEmpty
                ? _EmptyState(isSearch: _search.isNotEmpty)
                : ListView.separated(
                    padding: const EdgeInsets.fromLTRB(16, 4, 16, 100),
                    itemCount: filtered.length,
                    separatorBuilder: (_, __) => const SizedBox(height: 8),
                    itemBuilder: (context, i) {
                      final reel = filtered[i];
                      return ReelTile(
                        reel: reel,
                        onTap: () => _open(reel),
                        onToggleDone: () => provider.toggleDone(reel.id),
                        onEdit: () => Navigator.push(
                          context,
                          MaterialPageRoute(
                            builder: (_) => AddEditScreen(reel: reel),
                          ),
                        ),
                        onDelete: () => _confirmDelete(context, provider, reel),
                      );
                    },
                  ),
          ),
        ],
      ),
    );
  }

  Future<void> _open(Reel reel) async {
    if (reel.url.isEmpty) return;
    final uri = Uri.tryParse(reel.url);
    if (uri == null) return;
    if (await canLaunchUrl(uri)) {
      await launchUrl(uri, mode: LaunchMode.externalApplication);
    }
  }

  Future<void> _confirmDelete(
      BuildContext ctx, ReelProvider p, Reel reel) async {
    final ok = await showDialog<bool>(
      context: ctx,
      builder: (_) => AlertDialog(
        title: const Text('Delete reel?'),
        content: Text('Remove "${reel.title}" from your vault?'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx, false),
            child: const Text('Cancel'),
          ),
          FilledButton(
            onPressed: () => Navigator.pop(ctx, true),
            child: const Text('Delete'),
          ),
        ],
      ),
    );
    if (ok == true) p.deleteReel(reel.id);
  }
}

class _Chip extends StatelessWidget {
  final String label;
  final bool selected;
  final Color color;
  final VoidCallback onTap;

  const _Chip({
    required this.label,
    required this.selected,
    required this.color,
    required this.onTap,
  });

  @override
  Widget build(BuildContext context) {
    return GestureDetector(
      onTap: onTap,
      child: AnimatedContainer(
        duration: const Duration(milliseconds: 180),
        padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
        decoration: BoxDecoration(
          color: selected ? color : color.withOpacity(0.1),
          borderRadius: BorderRadius.circular(20),
          border: Border.all(
            color: selected ? color : color.withOpacity(0.35),
          ),
        ),
        child: Text(
          label,
          style: TextStyle(
            color: selected ? Colors.white : color,
            fontSize: 13,
            fontWeight: FontWeight.w500,
          ),
        ),
      ),
    );
  }
}

class _EmptyState extends StatelessWidget {
  final bool isSearch;
  const _EmptyState({required this.isSearch});

  @override
  Widget build(BuildContext context) {
    final theme = Theme.of(context);
    return Center(
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(
            isSearch ? Icons.search_off : Icons.bookmark_border_rounded,
            size: 56,
            color: theme.colorScheme.outline,
          ),
          const SizedBox(height: 12),
          Text(
            isSearch ? 'No results found' : 'Nothing saved yet',
            style: theme.textTheme.titleMedium,
          ),
          const SizedBox(height: 4),
          Text(
            isSearch
                ? 'Try a different search'
                : 'Tap + Add reel to get started',
            style: theme.textTheme.bodySmall?.copyWith(
              color: theme.colorScheme.outline,
            ),
          ),
        ],
      ),
    );
  }
}